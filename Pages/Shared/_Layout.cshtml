@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Mvc.ViewEngines
@inject IWebHostEnvironment Environment
@inject ICompositeViewEngine Engine
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Weightforce</title>
    <link rel="stylesheet" href="/css/tailwind.min.css" >
    <style>
        .bg-primary {
            --bg-opacity: 1;
            background-color: rgba(77, 125, 119, var(--bg-opacity));
        }
        .bg-accent {
            --bg-opacity: 1;
            background-color: rgba(121, 173, 166, var(--bg-opacity));
        }
    </style>
</head>
<body>
    <header>
      <img src="/login.jpg" alt="login image" class="w-full" />
      <div class="w-full py-2 bg-primary text-gray-300 flex justify-end">
          @{
              var result = Engine.FindView(ViewContext, "_LoginPartial", isMainPage: false);
          }
          @if (result.Success)
          {
              await Html.RenderPartialAsync("_LoginPartial");
          }
          else
          {
              throw new InvalidOperationException("The default Identity UI layout requires a partial view '_LoginPartial' " +
                  "usually located at '/Pages/_LoginPartial' or at '/Views/Shared/_LoginPartial' to work. Based on your configuration " +
                  $"we have looked at it in the following locations: {System.Environment.NewLine}{string.Join(System.Environment.NewLine, result.SearchedLocations)}.");
          }
      </div>
    </header>

    <div>
      <main role="main" class="pb-3">
        <div>
          <div class="flex justify-center">
            <section class="w-64 mt-4 ">
              @{
                var req = ViewContext.HttpContext.Request;
              }
              @if (req.Path == "/Identity/Account/Login" ){
                await Html.RenderPartialAsync("_LoginForm");
              }
              else if (req.Path == "/Identity/Account/Register" ){
                  await Html.RenderPartialAsync("_RegForm");
              }
              else if (req.Path == "/Identity/Account/ForgotPassword" ){
                  await Html.RenderPartialAsync("_RecoverPassword");
              }
              else if (req.Path == "/Identity/Account/Manage" ){
                <a href="/">Home</a>
              }
              else {
                @RenderBody()
              }
            </section>
          </div>
        </div>
      </main>
    </div>
    <script src="~/Identity/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/Identity/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
