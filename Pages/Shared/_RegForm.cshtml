<form id="registerForm" method="post">
  <div class="text-danger validation-summary-valid" data-valmsg-summary="true">
    <ul><li style="display:none"></li></ul>
  </div>
  <div class="mt-2 border bg-gray-300">
    📧
    <input
      class="bg-gray-300 w-10/12 focus:outline-none" type="email" data-val="true" data-val-email="The Email field is not a valid e-mail address." data-val-required="The Email field is required." id="Input_Email" name="Input.Email" value="" placeholder="Email Address" />
    <span class="text-danger field-validation-valid" data-valmsg-for="Input.Email" data-valmsg-replace="true"></span>
  </div>
  <div class="mt-2 border bg-gray-300">
    🔒
    <input
      class="bg-gray-300 w-10/12 focus:outline-none" type="password" data-val="true" data-val-length="The Password must be at least 6 and at max 100 characters long." data-val-length-max="100" data-val-length-min="6" data-val-required="The Password field is required." id="Input_Password" maxlength="100" name="Input.Password" placeholder="Password" />
    <span class="text-danger field-validation-valid" data-valmsg-for="Input.Password" data-valmsg-replace="true"></span>
  </div>
  <div class="mt-2 border bg-gray-300">
    🔒
    <input
      class="bg-gray-300 w-10/12 focus:outline-none" type="password" data-val="true" data-val-equalto="The password and confirmation password do not match." data-val-equalto-other="*.Password" id="Input_ConfirmPassword" name="Input.ConfirmPassword" placeholder="Confirm Password" />
    <span class="text-danger field-validation-valid" data-valmsg-for="Input.ConfirmPassword" data-valmsg-replace="true"></span>
  </div>
  <button id="registerSubmit" type="submit" class="bg-primary text-white w-full py-2 mt-2">Register</button>
</form>