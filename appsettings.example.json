{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=app.db",
    "ApplicationDBContext": "DataSource=app.db",
    "WeighForceIdentityDbContextConnection": "DataSource=app.db"
  },
  "Email": {
    "From": "labforce@mail.com",
    "SendGridToken": ""
  },
  "DB": {
    "OnTrack": {
      "String": "Data Source=.\\SQL2014;Initial Catalog=DMT;Integrated Security=true",
      "Connection": "SQLServer"
    },
    "App": {
      "String": "DataSource=app.db",
      "Connection": "SQlite"
    },
    "ID": {
      "String": "DataSource=app.db",
      "Connection": "SQlite"
    }
  },
  "SerialPort": {
    "Port": "COM1",
    "Baud": 9600,
    "StopBit": 1,
    "Handshake": 1,
    "Type": "LA2"
  },
  "InstallID": "Liwonde Rail",
  "LocalDeployment": false,
  "HTTPSRedirect": false,
  "Rail": {
    "From": "Nacala",
    "To": "Liwonde"
  },
  "Road": {
    "From": "Nacala",
    "To": "Blantyre"
  },
  "Sync": {
    "IsMaster": false,
    "Trains": false,
    "Meta": true,
    "CRMAddress": "",
    "IDAddress": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "IdentityServer4": "Error",
        "System.Net.Http.HttpClient": "Error",
        "Microsoft.Hosting.Lifetime": "Error",
        "Microsoft.EntityFrameworkCore.Database.Command": "Error"
      }
    },
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "Sample"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "None",
      "Microsoft": "None",
      "Microsoft.Hosting.Lifetime": "None",
      "System.Net.Http.HttpClient": "None"
    }
  },
  "IdentityServer": {
    "Key": {
      "Type": "File",
      "FilePath": "cert.pfx",
      "Password": "weighforc3"
    },
    "Clients": {
      "WeighForce": {
        "Profile": "SPA",
        "RedirectURI": "http://localhost:3000/authentication/login-callback",
        "LogoutURI": "http://localhost:3000/authentication/logout-callback"
      }
    }
  },
  "AllowedHosts": "*"
}